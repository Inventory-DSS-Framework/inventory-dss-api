APP_NAME="Inventory DSS API"
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/inventory_dss

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

JWT_SECRET_KEY=change-this-in-production-use-a-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

FTGM_ENGINE_BASE_URL=http://localhost:8010/api/v1
FTGM_ENGINE_TIMEOUT_SECONDS=30

STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=10
# Comma-separated list of allowed MIME types
ALLOWED_UPLOAD_MIME_TYPES=text/csv,application/vnd.ms-excel,application/json

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME="Inventory DSS"
